VITE_API_BASE_URL=/api

# --- 日志配置 ---
# VITE_LOG_RING_SIZE=500          # 内存环形缓冲区最大条目数
# VITE_LOG_DISK_MAX_SIZE=5242880  # IndexedDB 日志存储上限（5 MB）
# VITE_LOG_FLUSH_SIZE=100         # 批量刷盘条目数
# VITE_LOG_CONSOLE_LEVEL=debug    # 控制台最低输出级别 (debug | info | warn | error)
# VITE_LOG_BUFFER_LEVEL=info      # 缓冲区最低写入级别 (debug | info | warn | error)
