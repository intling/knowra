APP_NAME=knowra
APP_ENV=local
DEBUG=true
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+psycopg://knowra:knowra@localhost:5432/knowra
UPLOAD_STORAGE_DIR=storage/uploads
MAX_UPLOAD_BYTES=52428800
# Upload allow-list — independent of the parse allow-list below.
# To support PPTX uploads, add application/vnd.openxmlformats-officedocument.presentationml.presentation here as well.
ALLOWED_UPLOAD_CONTENT_TYPES=application/pdf,text/markdown,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.presentationml.presentation
DOCUMENT_PARSE_ENABLED=true
DOCUMENT_PARSE_ARTIFACT_DIR=storage/parsed
DOCUMENT_PARSE_MAX_BYTES=52428800
DOCUMENT_PARSE_MAX_PAGES=100
DOCUMENT_PARSE_OCR_ENABLED=false
# PDF parsing uses Docling model artifacts. In offline or restricted networks,
# pre-download them with:
# uv run docling-tools models download -o storage/docling-cache layout tableformer
DOCUMENT_PARSE_DOCLING_CACHE_DIR=storage/docling-cache
# Dispatcher type: only "background_tasks" is supported in this version.
DOCUMENT_PARSE_DISPATCHER=background_tasks
# Parse allow-list — independent of the upload allow-list above.
# A file must pass both lists to be parsed: it must be accepted by upload AND by parse.
DOCUMENT_PARSE_ALLOWED_CONTENT_TYPES=application/pdf,text/markdown,text/plain,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/vnd.openxmlformats-officedocument.wordprocessingml.document
DOCUMENT_PARSE_ALLOWED_EXTENSIONS=.docx,.md,.markdown,.pdf,.pptx,.txt
# Chunking runs after successful parsing and uses the same in-memory Docling document.
# HybridChunker and the Hugging Face tokenizer use DOCUMENT_PARSE_DOCLING_CACHE_DIR
# for local model/tokenizer cache. In restricted networks, pre-populate that cache.
DOCUMENT_CHUNKING_ENABLED=true
DOCUMENT_CHUNK_MAX_TOKENS=512
DOCUMENT_CHUNK_TOKENIZER_MODEL=Qwen/Qwen2-7B
DOCUMENT_CHUNK_MERGE_PEERS=true
DOCUMENT_CHUNK_REPEAT_TABLE_HEADER=true
DOCUMENT_CHUNK_INLINE_TEXT_MAX_BYTES=2048
# Long chunk text artifacts are written here when text exceeds the inline threshold.
DOCUMENT_CHUNK_ARTIFACT_STORAGE_DIR=storage/chunks
